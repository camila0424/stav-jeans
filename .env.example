# Variables de entorno — crea un archivo .env con estos valores reales
# NUNCA subas el .env a GitHub — ya está en .gitignore

# WooCommerce REST API (se consiguen en WP > WooCommerce > Configuración > Avanzado > REST API)
VITE_WC_URL=https://stavjeans.com/wp-json/wc/v3
VITE_WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram Graph API (se consigue en developers.facebook.com)
VITE_IG_TOKEN=tu_token_de_instagram_aqui
